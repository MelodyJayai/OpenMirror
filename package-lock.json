{
  "name": "openmirror",
  "version": "0.1.0",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "openmirror",
      "version": "0.1.0",
      "license": "GPL-3.0",
      "workspaces": [
        "packages/*",
        "apps/*"
      ],
      "engines": {
        "node": ">=20"
      }
    },
    "apps/cli": {
      "name": "@openmirror/cli",
      "version": "0.1.0",
      "license": "GPL-3.0",
      "dependencies": {
        "@openmirror/core": "*"
      },
      "bin": {
        "openmirror": "src/main.js"
      },
      "engines": {
        "node": ">=20"
      }
    },
    "node_modules/@openmirror/cli": {
      "resolved": "apps/cli",
      "link": true
    },
    "node_modules/@openmirror/core": {
      "resolved": "packages/core",
      "link": true
    },
    "packages/core": {
      "name": "@openmirror/core",
      "version": "0.1.0",
      "license": "GPL-3.0",
      "engines": {
        "node": ">=20"
      }
    }
  }
}
